# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexgen_shop
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins allowed
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# PayMongo (PH payments — plug in when ready)
PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=
